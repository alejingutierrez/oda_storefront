# Auth/API
ADMIN_TOKEN=replace_me
CATALOG_REFRESH_MONITOR_BASE_URL=https://oda-moda.vercel.app

# Frecuencia monitor
CATALOG_REFRESH_MONITOR_INTERVAL_MINUTES=5
CATALOG_REFRESH_MONITOR_CRON_MODE=light
CATALOG_REFRESH_MONITOR_INTERVENTION_MODE=active
CATALOG_REFRESH_MONITOR_NEAR_CLOSE_PROGRESS_PCT=95
CATALOG_REFRESH_MONITOR_NEAR_CLOSE_MAX_PENDING=40
CATALOG_REFRESH_MONITOR_NEAR_CLOSE_RUN_LIMIT=8
CATALOG_REFRESH_MONITOR_NEAR_CLOSE_MIN_CONSECUTIVE_CYCLES=2
CATALOG_REFRESH_MONITOR_HIGH_PROGRESS_CLOSE_LIMIT_PER_CYCLE=12
CATALOG_REFRESH_MONITOR_HIGH_PROGRESS_CLOSE_COOLDOWN_MINUTES=5
CATALOG_REFRESH_HIGH_PROGRESS_MIN_PCT=95
CATALOG_REFRESH_HIGH_PROGRESS_MAX_PENDING=10
CATALOG_REFRESH_HIGH_PROGRESS_NO_PROGRESS_MINUTES=5
CATALOG_REFRESH_HIGH_PROGRESS_FORCE_TERMINALIZE_REMAINING=true
CATALOG_REFRESH_SPEED_SLA_ITEMS_5M=120
CATALOG_REFRESH_SPEED_WARN_CYCLES=2
CATALOG_REFRESH_SPEED_CRITICAL_CYCLES=3
CATALOG_REFRESH_SPEED_CRITICAL_ITEMS_5M=60

# Reconcile reforzado
CATALOG_REFRESH_MONITOR_RECONCILE_JOB_SCAN_LIMIT=2500
CATALOG_REFRESH_MONITOR_RECONCILE_REENQUEUE_LIMIT=800
CATALOG_REFRESH_MONITOR_RECONCILE_INCLUDE_ACTIVE_ANALYSIS=true

# Remediación agresiva de tails
CATALOG_REFRESH_STUCK_REMEDIATE_THRESHOLD=20
CATALOG_REFRESH_MONITOR_REMEDIATE_COOLDOWN_MINUTES=30
CATALOG_REFRESH_MONITOR_REMEDIATE_LIMIT=60
CATALOG_REFRESH_MONITOR_REMEDIATE_MIN_NO_PROGRESS_MINUTES=20
CATALOG_REFRESH_MONITOR_REMEDIATE_PAUSE_OVER_CAP_TARGET=48
CATALOG_REFRESH_STUCK_TAIL_PROGRESS_PCT=95
CATALOG_REFRESH_STUCK_TAIL_MAX_REMAINING=0
CATALOG_REFRESH_STUCK_TAIL_STALE_MINUTES=60
CATALOG_REFRESH_STUCK_TAIL_FORCE_TERMINALIZE_REMAINING=true

# Guardrails
CATALOG_REFRESH_MONITOR_GUARDRAIL_CONSECUTIVE_CYCLES=2
CATALOG_REFRESH_MONITOR_HEARTBEAT_GUARDRAIL_CONSECUTIVE_CYCLES=2
CATALOG_REFRESH_MONITOR_GUARDRAIL_DRAIN_LIMIT=12
CATALOG_REFRESH_MONITOR_GUARDRAIL_DRAIN_MAX_MS=15000

# Timeouts y estado persistido
CATALOG_REFRESH_MONITOR_REQUEST_TIMEOUT_MS=45000
CATALOG_REFRESH_MONITOR_STATE_FILE=/opt/oda_storefront/reports/catalog_refresh_diagnostics/monitor-state.json
CATALOG_REFRESH_MONITOR_LOCK_FILE=/opt/oda_storefront/reports/catalog_refresh_diagnostics/monitor.lock
