{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1", "gru1"],
  "crons": [
    {
      "path": "/api/admin/brands/scrape/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/catalog-extractor/drain",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/admin/product-enrichment/drain",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/admin/catalog-refresh/cron?mode=light",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/admin/catalog-refresh/cron?mode=heavy",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/catalog-price-insights/cron",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/taxonomy-remap/auto-reseed/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/pricing/auto-usd-brands/cron",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/admin/home-trending/cron",
      "schedule": "0 5 * * *"
    }
  ]
}
